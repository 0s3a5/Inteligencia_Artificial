import pandas as pd
import numpy as np
from pgmpy.estimators import HillClimbSearch, ExhaustiveSearch, MaximumLikelihoodEstimator
from pgmpy.models import BayesianNetwork
from pgmpy.inference import VariableElimination
from pgmpy.sampling import BayesianModelSampling
from pgmpy.models import BayesianNetwork
from pgmpy.models import DiscreteBayesianNetwork
from pgmpy.inference import VariableElimination
from pgmpy.sampling import BayesianModelSampling
from hmmlearn import hmm
import warnings

import networkx as nx
import matplotlib.pyplot as plt

#se toman los datos del archivo que se entrega en canvas
#estos se separan por espacios y se dejan legibles para el progrmama

X_train = pd.read_csv('C:/Users/esteb/Documents/jupyter/UCI HAR Dataset/train/X_train.txt', sep=r'\s+', header=None)
y_train = pd.read_csv('C:/Users/esteb/Documents/jupyter/UCI HAR Dataset/train/y_train.txt', sep=r'\s+', header=None, names=['Activity'])
subj_train = pd.read_csv('C:/Users/esteb/Documents/jupyter/UCI HAR Dataset/train/subject_train.txt', sep=r'\s+', header=None, names=['Subject'])

X_test = pd.read_csv('C:/Users/esteb/Documents/jupyter/UCI HAR Dataset/test/X_test.txt', sep=r'\s+', header=None)
y_test = pd.read_csv('C:/Users/esteb/Documents/jupyter/UCI HAR Dataset/test/y_test.txt', sep=r'\s+', header=None, names=['Activity'])
subj_test = pd.read_csv('C:/Users/esteb/Documents/jupyter/UCI HAR Dataset/test/subject_test.txt', sep=r'\s+', header=None, names=['Subject'])

X_full = pd.concat([X_train, X_test], ignore_index=True)
y_full = pd.concat([y_train, y_test], ignore_index=True)
subj_full = pd.concat([subj_train, subj_test], ignore_index=True)

#las 5 columnas que faltan ya que dos sujeto y actividad sirven para el programa
columnas_seleccionadas = [0, 1, 2, 40, 41]
df_sensores = X_full[columnas_seleccionadas].copy()
df_sensores.columns = ['BodyAccX', 'BodyAccY', 'BodyAccZ', 'GravAccX', 'GravAccY']

#se dejan las 7 columnas
df = pd.concat([subj_full, y_full, df_sensores], axis=1)

#se dejan como variables discretas para que pueda trabajar pgmpy
columnas = ['BodyAccX', 'BodyAccY', 'BodyAccZ', 'GravAccX', 'GravAccY']
for col in columnas:
    df[col] = pd.qcut(df[col], q=3, labels=['1', '2', '3'])

# todo se pasa a string para que se tomen valores correctos y legibles
df['Subject'] = df['Subject'].astype(str)
df['Activity'] = df['Activity'].astype(str)


print("En este pedazo de coidgo se manipula la dataset que nos entregaron")
print("se utilizo la misma dataset que nos entrego el profesor porque era util y tenia mas de las columnas necesarias")
print("para esto se concatenan datos y se dejan solamnete 7 columnas utilies, esatas se eligen porque son utiles para utilizar matematicamente con pgmpy")
print("al final nos queda un dataset de las siguientes dimensiones:") 
print(f"Dimensiones del dataset: {df.shape}")



#HILL CLIMBING
print("Ejecutando Hill-Climbing")
hc = HillClimbSearch(df)
#se usa algoritmo bic(informacion bayesiana) que penaliza los modelos complejos
best_model_hc = hc.estimate(scoring_method="bic-d") 
print("muetsra de aristas", best_model_hc.edges())
print("Ejecutando busqueda exhaustiva)")
minimo = df[['Subject', 'Activity', 'BodyAccX', 'GravAccX']]

# busqueda exaustiva ahora prueba todos ls diagramas posiblesy calcula el bic para cada uno
#solo se ocupan 4 para evitar que la memoria explote
exh = ExhaustiveSearch(minimo, scoring_method="bic-d")

mejor = exh.estimate()

print("Aristas Exhaustive-Search:", mejor.edges())

# se pasan las  estructuras a objetos DiscreteBayesianNetwork
hc = DiscreteBayesianNetwork(best_model_hc.edges()) # hill climbing 
ex = DiscreteBayesianNetwork(mejor.edges()) # exaustiva

# todos los nodos existen, para que no hallan errores
hc.add_nodes_from(df.columns) # hill climbing 
ex.add_nodes_from(minimo.columns)# exaustiva




#estimacion de parametro
# verosimilitud (mle)
hc.fit(df, estimator=MaximumLikelihoodEstimator) #cuenta frecuencia de  hill climbing
ex.fit(minimo, estimator=MaximumLikelihoodEstimator) #cuenta frecuencia de exaustiva

# inferencia
hc_inferencia = VariableElimination(hc) #calculos bayesians en climbin
ex_inferencia = VariableElimination(ex) #calculos bayesianos en exaustiva

print(" inferencia de climbing")
# prueba de preguntas 
#pregunta 1 
#se sabe que 1 es walking asi que ¿probabilidad del nivel de aceleracion en x
res_hc1 = hc_inferencia.query(variables=['BodyAccX'], evidence={'Activity': '1'})
print(res_hc1)

# pregunta 2
# hay un nivel de alto de gravedad en x, ¿probabilidad de cada actividad?
res_hc2 = hc_inferencia.query(variables=['Activity'], evidence={'GravAccX': '3'})
print(res_hc2)

print("inferencia en exaustiva")
#se hacen  las mismas preguntas 
#pregunta 1 
#se sabe que 1 es walking asi que ¿probabilidad del nivel de aceleracion en x
res_exh1 = ex_inferencia.query(variables=['BodyAccX'], evidence={'Activity': '1'})
print(res_exh1)
# pregunta 2
# hay un nivel de alto de gravedad en x, ¿probabilidad de cada actividad?
res_exh2 = ex_inferencia.query(variables=['Activity'], evidence={'GravAccX': '3'})
print(res_exh2)

#datos sinteticos
#toma la red de climbin y lo usa como modelo
sampler = BayesianModelSampling(hc) 

#define cuanta data de mas genera
original = len(df)
porcentajes = [0.10, 0.20, 0.40]
for p in porcentajes:
    nueva = int(original * p)
    print(f"se crearon {nueva} muestras sinteticas que abaracan el  {int(p*100)}%")
    sintetico= sampler.forward_sample(size=nueva, show_progress=False) #crea lo que falta
    expandido = pd.concat([df, sintetico], ignore_index=True) #añade lo que falat al dataset
    #denuevo se hace el proceso de climibin
    hcnuevo = HillClimbSearch(expandido)
    hcexpandido= hcnuevo.estimate(scoring_method="bic-d")
    #se pasas a discrto 
    discretohc = DiscreteBayesianNetwork(hcexpandido.edges())
    discretohc.add_nodes_from(expandido.columns)
    # mle denuevo
    discretohc.fit(expandido, estimator=MaximumLikelihoodEstimator)
    #otra vez la pregunrta 1 
    #se sabe que 1 es walking asi que ¿probabilidad del nivel de aceleracion en x?
    resultados= VariableElimination(discretohc)
    print(f"\n pregunta con  +{int(p*100)}% de data sintetica")
    print(resultados.query(variables=['BodyAccX'], evidence={'Activity': '1'}))
